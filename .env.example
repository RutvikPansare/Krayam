# ── Supabase (required) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Signed email links (required) ───────────────────────────
# Any long random string: openssl rand -hex 32
TOKEN_SECRET=change-me

# ── Email — Resend (optional; without it, emails log to console) ──
RESEND_API_KEY=
EMAIL_FROM=Krayam <onboarding@resend.dev>
COMPANY_NAME=Bajaj Mukund Industries

# ── Site URL for links inside emails (use ngrok URL when testing with dad) ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Address printed on PO PDFs (single line; "\n" not supported in .env)
COMPANY_ADDRESS=Plot 14, MIDC Industrial Area, Pune, Maharashtra 411019

# ── Invoice OCR (Feature 12) — vision LLM, NOT open-source OCR ──
# Uses Claude vision via the Anthropic SDK to read PDF/image invoices.
ANTHROPIC_API_KEY=
INVOICE_OCR_MODEL=claude-opus-4-8
# Per-customer tolerances live in the organizations row (price 2% / qty 0% by
# default) and are overridable per tenant in Settings.

# ── Stock queries (Feature 09) ──────────────────────────────
# mock: reads the local materials mirror (default) | live: SAP API_MATERIAL_STOCK_SRV
STOCK_MODE=mock

# ── SAP (Features 03 + 06) — mock by default, no SAP needed ─
# mock: fake PR numbers, full pipeline works locally
# live: real OData call (ES5 Gateway / BTP Trial / Mukund QA / Prod)
SAP_MODE=mock
SAP_BASE_URL=
SAP_SERVICE_PATH=/sap/opu/odata/sap/MM_PUR_REQ_MAINTAIN_SRV
SAP_USER=
SAP_PASSWORD=
SAP_CLIENT=200
SAP_COMPANY_CODE=
SAP_PURCH_ORG=
SAP_PURCH_GROUP=
SAP_PLANT=
# Feature 06 — PO push
SAP_PO_SERVICE_PATH=/sap/opu/odata/sap/API_PURCHASEORDER_PROCESS_SRV
SAP_DEFAULT_SUPPLIER=
